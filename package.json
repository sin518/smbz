{
  "name": "sm1-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "build:frontend": "npm --workspace frontend run build",
    "start:frontend": "npm --workspace frontend run start",
    "start:backend": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "lint": "npm --workspace frontend run lint",
    "typecheck": "npm --workspace frontend run typecheck"
  },
  "engines": {
    "node": ">=20"
  }
}
